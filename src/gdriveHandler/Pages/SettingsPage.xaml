<Page
    x:Class="GdriveHandler.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid RowDefinitions="Auto,Auto,*" Padding="24,20,24,20" RowSpacing="16">

        <!-- Page title -->
        <TextBlock x:Uid="SettingsTitle" Grid.Row="0"
                   Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Subtab selector -->
        <SelectorBar x:Name="SubtabBar"
                     Grid.Row="1"
                     AutomationProperties.AutomationId="SettingsSubtabBar"
                     SelectionChanged="SubtabBar_SelectionChanged">
            <SelectorBarItem x:Name="SubtabGeneral"
                             AutomationProperties.AutomationId="SubtabGeneral"
                             Text="General"
                             Tag="general"/>
            <SelectorBarItem x:Name="SubtabAdvanced"
                             AutomationProperties.AutomationId="SubtabAdvanced"
                             Text="Advanced"
                             Tag="advanced"
                             Visibility="Collapsed"/>
            <SelectorBarItem x:Name="SubtabLogs"
                             AutomationProperties.AutomationId="SubtabLogs"
                             Text="Logs"
                             Tag="logs"
                             Visibility="Collapsed"/>
        </SelectorBar>

        <!-- Content panels — only one visible at a time -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">

                <!-- ==================== GENERAL ==================== -->
                <StackPanel x:Name="PanelGeneral" Spacing="16">

                    <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="0">

                            <!-- Open in new window -->
                            <Grid Padding="0,8,0,8" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock x:Uid="SettingsNewWindowLabel"/>
                                    <TextBlock x:Uid="SettingsNewWindowDesc"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="ToggleNewWindow"
                                             AutomationProperties.AutomationId="ToggleNewWindow"
                                             Grid.Column="1"
                                             MinWidth="0" OnContent="" OffContent=""
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Toggled="SettingToggled"/>
                            </Grid>

                            <MenuFlyoutSeparator/>

                            <!-- Include Edge profiles -->
                            <Grid Padding="0,8,0,8" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock x:Uid="SettingsEdgeLabel"/>
                                    <TextBlock x:Uid="SettingsEdgeDesc"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="ToggleEdge"
                                             AutomationProperties.AutomationId="ToggleEdge"
                                             Grid.Column="1"
                                             MinWidth="0" OnContent="" OffContent=""
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Toggled="SettingToggled"/>
                            </Grid>

                            <MenuFlyoutSeparator/>

                            <!-- Language -->
                            <Grid Padding="0,8,0,8" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock x:Uid="SettingsLanguageLabel"/>
                                    <TextBlock x:Uid="SettingsLanguageDesc"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:Name="LanguageCombo"
                                          AutomationProperties.AutomationId="LanguageCombo"
                                          Grid.Column="1"
                                          MinWidth="140"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          SelectionChanged="LanguageCombo_SelectionChanged">
                                    <ComboBoxItem Tag="en" Content="English"
                                                  AutomationProperties.AutomationId="LangEnglish"/>
                                    <ComboBoxItem Tag="tr" Content="Türkçe"
                                                  AutomationProperties.AutomationId="LangTurkish"/>
                                </ComboBox>
                            </Grid>

                            <MenuFlyoutSeparator/>

                            <!-- Advanced mode toggle -->
                            <Grid Padding="0,8,0,8" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock x:Uid="SettingsAdvancedModeLabel"/>
                                    <TextBlock x:Uid="SettingsAdvancedModeDesc"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="ToggleAdvanced"
                                             AutomationProperties.AutomationId="ToggleAdvancedMode"
                                             Grid.Column="1"
                                             MinWidth="0" OnContent="" OffContent=""
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Toggled="ToggleAdvanced_Toggled"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Inline "Saved" confirmation -->
                    <TextBlock x:Name="SavedConfirm"
                               x:Uid="SettingsSavedConfirm"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               Opacity="0"/>

                    <!-- Language-switch applying note -->
                    <TextBlock x:Name="LangApplyingNote"
                               AutomationProperties.AutomationId="LangApplyingNote"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               Visibility="Collapsed"/>

                </StackPanel>

                <!-- ==================== ADVANCED ==================== -->
                <StackPanel x:Name="PanelAdvanced" Spacing="16" Visibility="Collapsed">

                    <!-- Setup & Management -->
                    <TextBlock x:Uid="AdvSetupTitle"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="AdvManagedByWindowsText"
                                       x:Uid="AdvManagedByWindows"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                            <Button x:Name="AdvBtnOpenAppsSettings"
                                    x:Uid="AdvBtnOpenAppsSettings"
                                    AutomationProperties.AutomationId="AdvBtnOpenAppsSettings"
                                    Visibility="Collapsed"
                                    Click="AdvBtnOpenAppsSettings_Click"/>
                            <StackPanel x:Name="LegacySetupButtons"
                                        Orientation="Horizontal"
                                        Spacing="8">
                            <Button x:Name="AdvBtnInstallUser"
                                    x:Uid="AdvBtnInstallUser"
                                    AutomationProperties.AutomationId="AdvBtnInstallUser"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="AdvBtnInstallUser_Click"/>
                            <Button x:Name="AdvBtnInstallSystem"
                                    x:Uid="AdvBtnInstallSystem"
                                    AutomationProperties.AutomationId="AdvBtnInstallSystem"
                                    Click="AdvBtnInstallSystem_Click"/>
                            <Button x:Name="AdvBtnRepair"
                                    x:Uid="AdvBtnRepair"
                                    AutomationProperties.AutomationId="AdvBtnRepair"
                                    Click="AdvBtnRepair_Click"/>
                            <Button x:Name="AdvBtnReinstall"
                                    x:Uid="AdvBtnReinstall"
                                    AutomationProperties.AutomationId="AdvBtnReinstall"
                                    Click="AdvBtnReinstall_Click"/>
                            <Button x:Name="AdvBtnUninstall"
                                    x:Uid="AdvBtnUninstall"
                                    AutomationProperties.AutomationId="AdvBtnUninstall"
                                    Click="AdvBtnUninstall_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Maintenance -->
                    <TextBlock x:Uid="AdvMaintenanceTitle"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="AdvBtnOpenConfig"
                                    x:Uid="AdvBtnOpenConfig"
                                    AutomationProperties.AutomationId="AdvBtnOpenConfig"
                                    Click="AdvBtnOpenConfig_Click"/>
                            <Button x:Name="AdvBtnOpenLogs"
                                    x:Uid="AdvBtnOpenLogs"
                                    AutomationProperties.AutomationId="AdvBtnOpenLogs"
                                    Click="AdvBtnOpenLogs_Click"/>
                            <Button x:Name="AdvBtnDiagnose"
                                    x:Uid="AdvBtnDiagnose"
                                    AutomationProperties.AutomationId="AdvBtnDiagnose"
                                    Click="AdvBtnDiagnose_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Paths -->
                    <TextBlock x:Uid="AdvPathsTitle"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel x:Name="AdvPathsPanel" Spacing="8"/>
                    </Border>

                </StackPanel>

                <!-- ==================== LOGS ==================== -->
                <Grid x:Name="PanelLogs"
                      RowDefinitions="Auto,300,Auto"
                      RowSpacing="8"
                      Visibility="Collapsed">

                    <!-- Log toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Uid="LogsTitle"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                        <Button x:Uid="LogsBtnRefresh"
                                AutomationProperties.AutomationId="LogsBtnRefresh"
                                Click="LogsBtnRefresh_Click"
                                VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Log content -->
                    <Border Grid.Row="1"
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <ScrollViewer x:Name="LogScroller"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogText"
                                     AutomationProperties.AutomationId="LogTextBox"
                                     IsReadOnly="True" AcceptsReturn="True"
                                     FontFamily="Consolas" FontSize="12"
                                     TextWrapping="NoWrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="12"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Log footer -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="LogsBtnOpenNotepad"
                                AutomationProperties.AutomationId="LogsBtnOpenNotepad"
                                Click="LogsBtnOpenNotepad_Click"/>
                        <Button x:Uid="LogsBtnOpenFolder"
                                AutomationProperties.AutomationId="LogsBtnOpenFolder"
                                Click="LogsBtnOpenFolder_Click"/>
                        <Button x:Uid="LogsBtnClear"
                                AutomationProperties.AutomationId="LogsBtnClear"
                                Click="LogsBtnClear_Click"/>
                    </StackPanel>

                </Grid>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
