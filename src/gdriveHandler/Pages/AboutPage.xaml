<Page
    x:Class="GdriveHandler.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24,20,24,20">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">

            <!-- App header -->
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <Image Width="64" Height="64"
                       Source="ms-appx:///Assets/AppLogo.png"
                       AutomationProperties.AutomationId="AboutAppLogo"
                       AutomationProperties.Name="gdriveHandler application icon"/>
                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="gdriveHandler"
                               Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock x:Name="VersionText"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="by devSpaceOB"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Description -->
            <TextBlock x:Uid="AboutDescription" TextWrapping="Wrap"/>

            <HyperlinkButton x:Uid="AboutGitHub"
                             AutomationProperties.AutomationId="GitHubLink"
                             NavigateUri="https://github.com/devspaceOB/gdriveHandler"/>

            <!-- Paths -->
            <TextBlock x:Uid="AboutPathsTitle"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,8,0,0"/>
            <StackPanel x:Name="PathsPanel" Spacing="4"/>

            <!-- License -->
            <TextBlock x:Uid="AboutLicenseTitle"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,8,0,0"/>
            <TextBlock x:Uid="AboutLicense"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Icon note -->
            <TextBlock x:Uid="AboutIconNoteTitle"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,8,0,0"/>
            <TextBlock x:Uid="AboutIconNote"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        </StackPanel>
    </ScrollViewer>
</Page>
