<Page
    x:Class="GdriveHandler.Pages.AliasesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="32,24,32,24" RowSpacing="12">

        <TextBlock Grid.Row="0" Text="Aliases" Style="{StaticResource TitleTextBlockStyle}"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
            Map an old email address (From) to the current signed-in email (To).
            When a shortcut file carries the old address and no direct profile match is found,
            gdriveHandler will retry the match using the alias target.
        </TextBlock>

        <!-- Alias list -->
        <Border Grid.Row="2" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
                <!-- Column headers -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*,Auto" Padding="12,8,12,8"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Grid.Column="0" Text="From (old address)"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="To (current signed-in address)"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Width="36"/>
                </Grid>

                <ScrollViewer Grid.Row="1" MaxHeight="300">
                    <ItemsControl x:Name="AliasItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,*,Auto" Padding="8,4,8,4" ColumnSpacing="8">
                                    <TextBox Grid.Column="0"
                                             AutomationProperties.AutomationId="AliasFromBox"
                                             Text="{Binding From, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="old@gmail.com"/>
                                    <TextBox Grid.Column="1"
                                             AutomationProperties.AutomationId="AliasToBox"
                                             Text="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="current@domain.com"/>
                                    <Button Grid.Column="2" Width="32" Height="32"
                                            AutomationProperties.AutomationId="BtnRemoveAlias"
                                            AutomationProperties.Name="Remove alias row"
                                            Content="&#xE10A;"
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Click="BtnRemoveRow_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Row action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button AutomationProperties.AutomationId="BtnAddAlias"
                    Content="Add row" Click="BtnAddRow_Click"/>
            <Button AutomationProperties.AutomationId="BtnSaveAliases"
                    Content="Save" Click="BtnSave_Click"
                    Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>

        <!-- Detect profiles section -->
        <Border Grid.Row="4" CornerRadius="8" Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock Text="Detect installed profiles" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    List all Chrome and Edge profiles found on this machine with their signed-in email.
                    Use this to copy the correct "To" address for an alias.
                </TextBlock>
                <Button AutomationProperties.AutomationId="BtnDetectProfiles"
                        Content="Detect profiles" Click="BtnDetectProfiles_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
