<Page
    x:Class="GdriveHandler.Pages.AliasesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="24,20,24,20" RowSpacing="12"
          MaxWidth="720" HorizontalAlignment="Left">

        <TextBlock Grid.Row="0"
                   x:Uid="AliasesTitle"
                   Style="{StaticResource TitleTextBlockStyle}"/>

        <TextBlock Grid.Row="1"
                   x:Uid="AliasesDescription"
                   TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <!-- Alias list -->
        <Border Grid.Row="2"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
                <!-- Column headers -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,*,Auto"
                      Padding="12,8,12,8"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <TextBlock Grid.Column="0"
                               x:Uid="AliasesColFrom"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               x:Uid="AliasesColTo"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Width="36"/>
                </Grid>

                <ScrollViewer Grid.Row="1" MaxHeight="300">
                    <ItemsControl x:Name="AliasItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,*,Auto" Padding="8,4,8,4" ColumnSpacing="8">
                                    <TextBox Grid.Column="0"
                                             AutomationProperties.AutomationId="AliasFromBox"
                                             Text="{Binding From, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="old@gmail.com"/>
                                    <TextBox Grid.Column="1"
                                             AutomationProperties.AutomationId="AliasToBox"
                                             Text="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="current@domain.com"/>
                                    <Button Grid.Column="2" Width="32" Height="32"
                                            AutomationProperties.AutomationId="BtnRemoveAlias"
                                            AutomationProperties.Name="Remove alias row"
                                            Content="&#xE10A;"
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Click="BtnRemoveRow_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Row action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button x:Uid="AliasesBtnAddRow"
                    AutomationProperties.AutomationId="BtnAddAlias"
                    Click="BtnAddRow_Click"/>
            <Button x:Uid="AliasesBtnSave"
                    AutomationProperties.AutomationId="BtnSaveAliases"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="BtnSave_Click"/>
        </StackPanel>

        <!-- Detect profiles section -->
        <Border Grid.Row="4"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock x:Uid="AliasesDetectTitle"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Uid="AliasesDetectDesc"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:Uid="AliasesBtnDetect"
                        AutomationProperties.AutomationId="BtnDetectProfiles"
                        Click="BtnDetectProfiles_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
