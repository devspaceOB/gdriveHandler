<Page
    x:Class="GdriveHandler.Pages.LogViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid RowDefinitions="Auto,*,Auto" Padding="32,24,32,24" RowSpacing="12">

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Application Log" Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <Button AutomationProperties.AutomationId="BtnRefreshLog"
                    Content="Refresh" Click="BtnRefresh_Click"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Log content -->
        <Border Grid.Row="1" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <ScrollViewer x:Name="LogScroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogText"
                         AutomationProperties.AutomationId="LogTextBox"
                         IsReadOnly="True" AcceptsReturn="True"
                         FontFamily="Consolas" FontSize="12"
                         TextWrapping="NoWrap"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="12"/>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button AutomationProperties.AutomationId="BtnOpenNotepad"
                    Content="Open in Notepad" Click="BtnOpenNotepad_Click"/>
            <Button AutomationProperties.AutomationId="BtnOpenLogsFolder"
                    Content="Open logs folder" Click="BtnOpenFolder_Click"/>
            <Button AutomationProperties.AutomationId="BtnClearLog"
                    Content="Clear log" Click="BtnClear_Click"/>
        </StackPanel>

    </Grid>
</Page>
