<Page
    x:Class="GdriveHandler.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <ScrollViewer Padding="32,24,32,24">
        <StackPanel Spacing="16" MaxWidth="680" HorizontalAlignment="Left">

            <!-- Status Card -->
            <Border x:Name="StatusBorder" CornerRadius="8" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="StatusTitle" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="StatusDetail"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Description -->
            <TextBlock TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                Opens Google Workspace shortcuts (.gdoc, .gsheet, .gslides, …) in the Chrome or Edge
                profile signed in with the account stored in the file — so multi-account users always
                land in the right profile instead of seeing "you need access".
            </TextBlock>

            <!-- Actions -->
            <TextBlock Text="Installation" Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,8,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="8" x:Name="ActionPanel">
                <Button x:Name="BtnInstallUser"
                        AutomationProperties.AutomationId="BtnInstallUser"
                        Content="Install for me (no admin)"
                        Click="BtnInstallUser_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="BtnInstallSystem"
                        AutomationProperties.AutomationId="BtnInstallSystem"
                        Content="Install for all users (admin)"
                        Click="BtnInstallSystem_Click"/>
                <Button x:Name="BtnRepair"
                        AutomationProperties.AutomationId="BtnRepair"
                        Content="Repair"
                        Click="BtnRepair_Click"/>
                <Button x:Name="BtnUninstall"
                        AutomationProperties.AutomationId="BtnUninstall"
                        Content="Uninstall"
                        Click="BtnUninstall_Click"/>
            </StackPanel>

            <!-- Utilities -->
            <TextBlock Text="Utilities" Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,8,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button AutomationProperties.AutomationId="BtnOpenConfig"
                        Content="Open config.ini" Click="BtnOpenConfig_Click"/>
                <Button AutomationProperties.AutomationId="BtnOpenLogs"
                        Content="Open logs folder" Click="BtnOpenLogs_Click"/>
                <Button AutomationProperties.AutomationId="BtnDiagnose"
                        Content="Run diagnostics" Click="BtnDiagnose_Click"/>
            </StackPanel>

            <!-- Paths info -->
            <TextBlock Text="Paths" Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,8,0,0"/>
            <StackPanel x:Name="PathsPanel" Spacing="4"/>

        </StackPanel>
    </ScrollViewer>
</Page>
