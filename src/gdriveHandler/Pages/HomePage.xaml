<Page
    x:Class="GdriveHandler.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <ScrollViewer Padding="24,20,24,20">
        <StackPanel Spacing="24" MaxWidth="720" HorizontalAlignment="Left">

            <!-- Hero -->
            <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <Image Width="64" Height="64"
                       Source="ms-appx:///Assets/AppLogo.png"
                       AutomationProperties.AutomationId="HomeAppLogo"
                       AutomationProperties.Name="gdriveHandler icon"/>
                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="gdriveHandler"
                               Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock x:Name="HeroTagline"
                               x:Uid="HomeTagline"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Status card -->
            <Border x:Name="StatusBorder"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="StatusTitle"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="StatusDetail"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <!-- CTA shown only when not installed -->
                    <Button x:Name="BtnSetup"
                            x:Uid="HomeBtnSetup"
                            AutomationProperties.AutomationId="BtnSetupGdriveHandler"
                            Style="{StaticResource AccentButtonStyle}"
                            Visibility="Collapsed"
                            Click="BtnSetup_Click"/>
                </StackPanel>
            </Border>

            <!-- How it works -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="HomeHowItWorksTitle"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>

                <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="HomeStep1" TextWrapping="Wrap" LineHeight="20"/>
                        <TextBlock x:Uid="HomeStep2" TextWrapping="Wrap" LineHeight="20"/>
                        <TextBlock x:Uid="HomeStep3" TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <HyperlinkButton x:Name="LinkGuide"
                                     x:Uid="HomeLinkGuide"
                                     AutomationProperties.AutomationId="HomeLinkGuide"
                                     Click="LinkGuide_Click"/>
                    <TextBlock Text="·" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <HyperlinkButton x:Name="LinkAliases"
                                     x:Uid="HomeLinkAliases"
                                     AutomationProperties.AutomationId="HomeLinkAliases"
                                     Click="LinkAliases_Click"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
