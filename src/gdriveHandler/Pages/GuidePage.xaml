<Page
    x:Class="GdriveHandler.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24,20,24,20">
        <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock x:Uid="GuideTitle"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- What it does -->
            <TextBlock x:Uid="GuideWhatItDoesTitle"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0"/>
            <TextBlock x:Uid="GuideWhatItDoes"
                       TextWrapping="Wrap" LineHeight="22"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Supported files -->
            <TextBlock x:Uid="GuideSupportedFilesTitle"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0"/>
            <TextBlock x:Name="ExtensionsText"
                       IsTextSelectionEnabled="True"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- How it finds the right profile -->
            <TextBlock x:Uid="GuideHowMatchingTitle"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0"/>
            <TextBlock x:Uid="GuideHowMatching"
                       TextWrapping="Wrap" LineHeight="22"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Open the right account — aliases -->
            <TextBlock x:Uid="GuideOpenRightAccountTitle"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0"/>
            <TextBlock x:Uid="GuideOpenRightAccount"
                       TextWrapping="Wrap" LineHeight="22"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Example file -->
            <TextBlock x:Uid="GuideSampleTitle"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0"/>
            <Border CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <TextBox IsReadOnly="True" AcceptsReturn="True"
                         FontFamily="Consolas" FontSize="12"
                         TextWrapping="NoWrap" BorderThickness="0"
                         Background="Transparent"
                         AutomationProperties.AutomationId="SampleCodeBlock"
                         Text="{x:Bind SampleJson, Mode=OneTime}"/>
            </Border>

            <!-- Edge note -->
            <TextBlock x:Uid="GuideEdgeNoteTitle"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,4,0,0"/>
            <TextBlock x:Uid="GuideEdgeNote"
                       TextWrapping="Wrap" LineHeight="22"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        </StackPanel>
    </ScrollViewer>
</Page>
